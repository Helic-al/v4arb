[submodule "solidityHook/lib/v4-core"]
	path = solidityHook/lib/v4-core
	url = https://github.com/Uniswap/v4-core
[submodule "solidityHook/lib/forge-std"]
	path = solidityHook/lib/forge-std
	url = https://github.com/foundry-rs/forge-std
[submodule "solidityHook/lib/v4-periphery"]
	path = solidityHook/lib/v4-periphery
	url = https://github.com/Uniswap/v4-periphery
	ignore =  untracked
[submodule "solidityHook/lib/v3-periphery"]
	path = solidityHook/lib/v3-periphery
	url = https://github.com/Uniswap/v3-periphery
[submodule "lib/v3-core"]
	path = lib/v3-core
	url = https://github.com/Uniswap/v3-core
[submodule "solidityHook/lib/v3-core"]
	path = solidityHook/lib/v3-core
	url = https://github.com/Uniswap/v3-core
